<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Portfolio</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<!-- Navbar -->
<nav>
  <h2>MyPortfolio</h2>
  <ul>
    <li><a href="#about">About</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<!-- Hero -->
<section class="hero">
  <h1>Hello, I'm <span>Your Name</span></h1>
  <p>Web Developer | Designer | Student</p>
  <a href="#projects" class="btn">View Work</a>
</section>

<!-- About -->
<section id="about">
  <h2>About Me</h2>
  <p>I am a passionate developer skilled in HTML, CSS, and JavaScript.</p>
</section>

<!-- Projects -->
<section id="projects">
  <h2>Projects</h2>
  <div class="project-container">
    <div class="project-card">
      <h3>Calculator</h3>
      <p>Simple calculator using JS</p>
    </div>
    <div class="project-card">
      <h3>Image Gallery</h3>
      <p>Responsive gallery with lightbox</p>
    </div>
  </div>
</section>

<!-- Skills -->
<section id="skills">
  <h2>Skills</h2>
  <ul>
    <li>HTML</li>
    <li>CSS</li>
    <li>JavaScript</li>
  </ul>
</section>

<!-- Contact -->
<section id="contact">
  <h2>Contact Me</h2>
  <p>Email: your@email.com</p>
</section>

<footer>
  <p>© 2026 Your Name</p>
</footer>

<script src="script.js"></script>
</body>
</html>
